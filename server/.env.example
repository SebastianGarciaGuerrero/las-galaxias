# Copia este archivo como server/.env y rellena con tus valores.
# Los mismos valores que tienes en Vercel > Project Settings > Environment Variables.

SUPABASE_URL=https://opvnwbkyrnnejhmkiool.supabase.co

# OJO: tiene que ser la "service_role" key (no la anon/publishable),
# para poder escribir en las tablas. La encuentras en:
# Supabase > Project Settings > API > service_role secret
SUPABASE_KEY=

# Opcional. Por defecto 3001.
PORT=3001

# Solo si vas a probar uploads a Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
